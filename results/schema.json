{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/CataDef/LongMemCode/blob/main/results/schema.json",
  "title": "LongMemCodeResult",
  "description": "One submission to the LongMemCode scoreboard. See results/README.md for the narrative version.",
  "type": "object",
  "required": ["longmemcode_version", "adapter", "corpus", "machine", "summary", "per_category"],
  "additionalProperties": false,
  "properties": {
    "longmemcode_version": {
      "type": "string",
      "description": "Benchmark version this result was produced against. Matches tag on the LongMemCode repo, e.g. '0.1'."
    },
    "adapter": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "repo": { "type": "string", "format": "uri" },
        "description": { "type": "string" }
      }
    },
    "corpus": {
      "type": "object",
      "required": ["name", "commit", "scenarios_sha256"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "enum": ["fastapi", "clap"] },
        "commit": { "type": "string" },
        "scenarios_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "scenarios_count": { "type": "integer", "minimum": 1 }
      }
    },
    "machine": {
      "type": "object",
      "required": ["cpu", "ram_gb", "os"],
      "additionalProperties": true,
      "properties": {
        "cpu": { "type": "string" },
        "ram_gb": { "type": "number", "minimum": 0 },
        "os": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "weighted_accuracy",
        "raw_accuracy",
        "p50_latency_ms",
        "p95_latency_ms",
        "cost_per_1k_queries_usd"
      ],
      "additionalProperties": true,
      "properties": {
        "weighted_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
        "raw_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
        "p50_latency_ms": { "type": "number", "minimum": 0 },
        "p95_latency_ms": { "type": "number", "minimum": 0 },
        "p99_latency_ms": { "type": "number", "minimum": 0 },
        "total_tokens_returned": { "type": "integer", "minimum": 0 },
        "baseline_repo_tokens": { "type": "integer", "minimum": 0 },
        "compression_ratio": { "type": "number", "minimum": 0 },
        "total_cost_usd": { "type": "number", "minimum": 0 },
        "cost_per_1k_queries_usd": { "type": "number", "minimum": 0 }
      }
    },
    "per_category": {
      "type": "object",
      "patternProperties": {
        "^(completion|bug_fix|refactor|test_gen|feature_add|api_discovery)$": {
          "type": "object",
          "required": ["n", "passed", "avg_score"],
          "properties": {
            "n": { "type": "integer", "minimum": 0 },
            "passed": { "type": "integer", "minimum": 0 },
            "avg_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "avg_precision": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "avg_recall": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "per_scenario_jsonl": {
      "type": "string",
      "description": "Relative path (inside results/) to the full per-scenario JSONL. Gzipped if larger than ~100 kB."
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
